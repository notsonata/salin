{
  "name": "salin",
  "private": true,
  "workspaces": [
    "apps/web",
    "packages/shared"
  ],
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @salin/web test:e2e",
    "generate:openapi": "python3 apps/api/scripts/export_openapi.py",
    "generate:shared": "pnpm --filter @salin/shared generate",
    "docker:build": "docker compose -f infra/docker-compose.yml build"
  }
}
