APP_ENV=development
DATABASE_URL=postgresql+psycopg://salin:salin@postgres:5432/salin
REDIS_URL=redis://redis:6379/0
CORS_ALLOWED_ORIGINS=http://localhost:3000

R2_BUCKET_NAME=salin-dev
R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=changeme
R2_SECRET_ACCESS_KEY=changeme
R2_REGION=auto

GROQ_API_KEY=changeme
GROQ_TRANSCRIPTION_MODEL=whisper-large-v3
GROQ_FAST_MODEL=whisper-large-v3-turbo

OPENROUTER_API_KEY=changeme
OPENROUTER_MODELS=openai/gpt-4.1-mini,anthropic/claude-3.5-haiku

LOCAL_TRANSCRIPTION_MODEL=small

MAX_UPLOAD_MB=100

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
SALIN_API_INTERNAL_BASE_URL=http://api:8000
